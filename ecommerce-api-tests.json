    {
      "name": "Place Order",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const cartId = pm.collectionVariables.get(\"cartId\");\r",
              "\r",
              "pm.test(\"cartId set\", () => {\r",
              "  pm.expect(cartId).to.exist;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201\", () => {\r",
              "  pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "const res = pm.response.json();\r",
              "\r",
              "pm.test(\"Order ID present\", () => {\r",
              "  pm.expect(res.id).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Order not failed\", () => {\r",
              "  pm.expect(res.id).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"orderId\", res.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"userId\": 1,\r\n  \"products\": [\r\n    {\r\n      \"id\": {{productId}},\r\n      \"quantity\": 2\r\n    }\r\n  ]\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/carts/add?Authorization={{token}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "carts",
            "add"
          ],
          "query": [
            {
              "key": "Authorization",
              "value": "{{token}}"
            }
          ]
        }
      },
      "response": []
