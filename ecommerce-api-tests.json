    {
      "name": "Logout",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", () => {\r",
              "  pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"token\", \"\");\r",
              "\r",
              "pm.test(\"Token cleared\", () => {\r",
              "  const t = pm.collectionVariables.get(\"token\");\r",
              "  pm.expect(t).to.equal(\"\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const token = pm.collectionVariables.get(\"token\");\r",
              "console.log(\"Token being used:\", token);\r",
              "\r",
              "pm.test(\"Token exists before logout\", () => {\r",
              "  pm.expect(token).to.be.a(\"string\").and.not.empty;\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "logout"
          ]
        }
      },
      "response": []
